{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "MDMServer": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/mdmserver/mdm-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  }
}